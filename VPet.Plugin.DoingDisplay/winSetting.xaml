<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="VPet.Plugin.DoingDisplay.winSetting" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ll="clr-namespace:LinePutScript.Localization.WPF;assembly=LinePutScript.Localization.WPF"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:VPet.Plugin.DoingDisplay" mc:Ignorable="d"
        xmlns:pu="clr-namespace:Panuon.WPF.UI;assembly=Panuon.WPF.UI" Title="{ll:Str '在做了在做了'}" Width="550" Height="650"
        MinWidth="300" MinHeight="300" FontSize="16" ResizeMode="CanResize"
        Background="{DynamicResource PrimaryLighter}" Closing="Window_Closing">
    <Window.Resources>
        <ResourceDictionary Source="/VPet-Simulator.Windows.Interface;component/ResourceStyle.xaml" />
    </Window.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,6" TextWrapping="WrapWithOverflow">
            <Run Text="{ll:Str DoingDisplay}" FontWeight="Bold" /> : 
            <Run Text="{ll:Str '记录各软件的使用时长统计信息'}" /><LineBreak />
            <Run Text="{ll:Str '如需展示在Steam状态, 请进行任意工作/玩耍/学习'}" />
        </TextBlock>

        <TabControl Grid.Row="1" Background="{DynamicResource PrimaryLighter}" BorderThickness="0"
                pu:TabControlHelper.HeaderPanelBackground="{DynamicResource PrimaryLight}"
                pu:TabControlHelper.ItemsSelectedBackground="{DynamicResource PrimaryLighter}">
            <!-- Tab 1: 软件统计 -->
            <TabItem Header="{ll:Str '软件统计'}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,4,0,6">
                        <TextBlock Text="{ll:Str '排序:'}" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="13" />
                        <RadioButton x:Name="rbSortLastUse" Content="{ll:Str '最近使用'}" GroupName="SortGroup"
                                IsChecked="True" Tag="LastUse" Checked="RbSort_Checked" Margin="0,0,10,0" />
                        <RadioButton x:Name="rbSortName" Content="{ll:Str '软件名称'}" GroupName="SortGroup" Tag="Name"
                                Checked="RbSort_Checked" Margin="0,0,10,0" />
                        <RadioButton x:Name="rbSortToday" Content="{ll:Str '今日时长'}" GroupName="SortGroup"
                                Tag="TodayMinute" Checked="RbSort_Checked" Margin="0,0,10,0" />
                        <RadioButton x:Name="rbSortTotal" Content="{ll:Str '累计时长'}" GroupName="SortGroup"
                                Tag="TotalMinute" Checked="RbSort_Checked" />
                        <Button x:Name="btnSortDir" Content="↓" Width="28" Margin="8,0,0,0"
                                pu:ButtonHelper.CornerRadius="4" BorderBrush="{DynamicResource SecondaryDark}"
                                BorderThickness="1" Background="{DynamicResource SecondaryLight}"
                                Click="BtnSortDir_Click" />
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="icStatisticals">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" Padding="8,6" BorderBrush="{DynamicResource SecondaryDark}"
                                            BorderThickness="1" CornerRadius="4">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- 软件信息行 -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBox
                                                            Text="{Binding SoftWare, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            FontSize="14" FontWeight="SemiBold"
                                                            BorderThickness="0,0,0,1"
                                                            BorderBrush="{DynamicResource SecondaryDark}"
                                                            Background="Transparent" ToolTip="{ll:Str '点击可编辑软件名称'}" />
                                                    <TextBlock Text="{Binding SoftWareProcessName}" FontSize="11"
                                                            Foreground="Gray" Margin="2,2,0,0" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding DurationText}"
                                                        ToolTip="{ll:Str '累计时长'}" VerticalAlignment="Center"
                                                        Margin="12,0" FontSize="14" FontWeight="SemiBold" />
                                                <TextBlock Grid.Column="2"
                                                        Text="{Binding LastUse, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                        VerticalAlignment="Center" FontSize="11" Foreground="Gray"
                                                        Margin="0,0,4,0" ToolTip="{ll:Str '最近使用'}" />
                                            </Grid>

                                            <!-- 最近7天使用柱状图 -->
                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding DailyStats}"
                                                    Margin="0,8,0,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="1" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel HorizontalAlignment="Center" Margin="2,0">
                                                            <TextBlock Text="{Binding DurationText}" FontSize="9"
                                                                    HorizontalAlignment="Center" Foreground="Gray"
                                                                    Margin="0,0,0,2" />
                                                            <Grid Height="36" Width="24">
                                                                <Rectangle Fill="{DynamicResource SecondaryLight}"
                                                                        Opacity="0.4" RadiusX="2" RadiusY="2" />
                                                                <Rectangle Fill="{DynamicResource Secondary}"
                                                                        Height="{Binding BarHeight}"
                                                                        VerticalAlignment="Bottom" RadiusX="2"
                                                                        RadiusY="2" />
                                                            </Grid>
                                                            <TextBlock Text="{Binding Day}" FontSize="10"
                                                                    HorizontalAlignment="Center" Margin="0,2,0,0" />
                                                            <TextBlock Text="{Binding DateStr}" FontSize="9"
                                                                    HorizontalAlignment="Center" Foreground="Gray" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Tab 2: 使用历史 -->
            <TabItem Header="{ll:Str '使用历史'}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,4,0,6">
                        <RadioButton x:Name="rbDaily" Content="{ll:Str '每日'}" IsChecked="True" Margin="0,0,16,0"
                                Checked="RbDaily_Checked" />
                        <RadioButton x:Name="rbMonthly" Content="{ll:Str '每月'}" Checked="RbMonthly_Checked" />
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="icHistory">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" Padding="8,6" BorderBrush="{DynamicResource SecondaryDark}"
                                            BorderThickness="1" CornerRadius="4">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- 日期/月份标题行 -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Header}" FontSize="14"
                                                            FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding SubHeader}" FontSize="12"
                                                            Foreground="Gray" VerticalAlignment="Bottom"
                                                            Margin="6,0,0,1" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding DurationText}" FontSize="14"
                                                        FontWeight="SemiBold" VerticalAlignment="Center" />
                                            </Grid>

                                            <!-- 各软件用量条形列表 -->
                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding TopSoftware}"
                                                    Margin="0,6,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110" />
                                                                <ColumnDefinition Width="1*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                                    FontSize="11" VerticalAlignment="Center"
                                                                    TextTrimming="CharacterEllipsis" />
                                                            <ProgressBar Grid.Column="1" Value="{Binding Fraction}"
                                                                    Maximum="100" Height="8" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="2" Text="{Binding DurationText}"
                                                                    FontSize="11" VerticalAlignment="Center"
                                                                    Margin="8,0,0,0" Foreground="Gray" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="{ll:Str '清空统计'}" Margin="0,0,4,0" Background="{DynamicResource Secondary}"
                    pu:ButtonHelper.CornerRadius="4" BorderBrush="{DynamicResource SecondaryDark}" BorderThickness="2"
                    Click="BtnClear_Click" />
            <Button Grid.Column="1" Content="{ll:Str '刷新统计时长'}" Margin="4,0,0,0"
                    Background="{DynamicResource SecondaryLight}" pu:ButtonHelper.CornerRadius="4"
                    BorderBrush="{DynamicResource SecondaryDark}" BorderThickness="2" Click="BtnSave_Click" />
        </Grid>
    </Grid>
</Window>
